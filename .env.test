# Override for `npm test` only. Points vitest at the isolated Postgres on port
# 5433 (docker service `db-test`) so test writes never touch the dev database.
# Loaded automatically by tests/setup.ts (dotenv/config) when vitest is run
# with NODE_ENV=test or env var VITEST is set (our npm test script below does).
DATABASE_URL=postgres://orderlink_user:devpw@localhost:5433/orderlink_test
NEXT_PUBLIC_OTP_GATE_ENABLED=false
# Razorpay secrets re-read from .env; they're signing secrets only, no side effects.
