# Core
DATABASE_URL=postgres://orderlink_user:CHANGE_ME@localhost:5432/orderlink
SITE_URL=http://localhost:3000

# Razorpay (test mode for local dev)
RAZORPAY_KEY_ID=rzp_test_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME

# Email — ALL customer + admin emails are sent from Salesforce Flow.
# No transactional email provider is used from the Node backend.

# Admin basic-auth
ADMIN_USERNAME=vinay
ADMIN_PASSWORD_BCRYPT=CHANGE_ME

# Column-level encryption for pending_sf_sync payloads (base64 of 32 random bytes)
ENCRYPTION_KEY=CHANGE_ME_base64_32_bytes

# Sentry (blank for local dev to disable — Sentry.init() is skipped entirely)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Salesforce
SF_LOGIN_URL=https://codesierra.my.salesforce.com
SF_CONSUMER_KEY=CHANGE_ME
SF_USERNAME=integration@codesierra.tech.orderlink
SF_JWT_PRIVATE_KEY_PATH=./sf-jwt.pem
SF_PERSON_ACCOUNT_RECORD_TYPE_ID=012CHANGE_ME
SF_ORDER_RECORD_TYPE_ID=012CHANGE_ME
SF_PRODUCT_RECORD_TYPE_ID=012CHANGE_ME
SF_EXTERNAL_ID_PREFIX=orderlink
SF_SYNC_ENABLED=true

# Mobile OTP gate on checkout.
# Set "true" to require WhatsApp OTP verification before order submit.
# Phase 2a launches with this OFF: POD requires ₹49 advance via Razorpay and
# prepaid requires full payment, so fake orders still cost the fraudster money —
# spam risk is low enough that we skip the OTP friction at launch and flip this
# on later if abuse shows up.
NEXT_PUBLIC_OTP_GATE_ENABLED=false

# MSG91 WhatsApp OTP (used ONLY when NEXT_PUBLIC_OTP_GATE_ENABLED=true).
# Phase 2a uses WhatsApp as the ONLY OTP channel — no SMS, no DLT registration.
# MSG91_OTP_TEMPLATE_ID must be a Meta-approved WhatsApp Authentication template
# linked from MSG91 (not a DLT SMS template).
MSG91_AUTH_KEY=CHANGE_ME
MSG91_OTP_TEMPLATE_ID=CHANGE_ME
# HMAC secret for the signed otp-verified cookie (base64 of 32 random bytes).
# Different from ENCRYPTION_KEY so rotating one does not invalidate the other.
OTP_COOKIE_SECRET=CHANGE_ME_base64_32_bytes
# Dev-mode bypass: when NODE_ENV!=production AND MSG91_AUTH_KEY is empty,
# the code "123456" always verifies. Lets you test checkout locally without MSG91 keys.

# Feature flags
FOMO_POPUP_ENABLED=true

# Gemini image-generation pipeline (scripts/generate-images).
# Used by the ad-hoc content pipeline that turns reference photos in
# assets/products/<folder>/ into thumbnail + PDP + social creatives.
# See memory: orderlink-image-generation-workflow.md
GEMINI_API_KEY=CHANGE_ME
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
